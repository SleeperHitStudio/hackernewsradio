# The only config you need: a Sleeper Hit Studio API key.
# Mint one at https://sleeperhit.studio (dashboard → API keys) with scopes:
#   story:read story:write source:read source:write artifact:read artifact:publish credits:read
SLEEPERHIT_API_KEY=sh_xxx_xxx

# Which Story API to drive. Defaults to prod; override for stage or local.
# SLEEPERHIT_API_BASE=https://sleeperhit.studio
# SLEEPERHIT_API_BASE=https://stage.sleeperhit.studio
# SLEEPERHIT_API_BASE=http://localhost:5500

# Backend port (Vite dev proxies /api here). Default 5780.
# PORT=5780
